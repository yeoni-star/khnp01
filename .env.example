# Supabase 프로젝트 > Settings > Database > Connection string 에서 확인
# Connection pooling(Transaction mode, 포트 6543) 문자열 - 앱 런타임 쿼리용
DATABASE_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection(포트 5432) 문자열 - prisma migrate/db push 등 CLI 전용
DIRECT_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# 로그인 공용 비밀번호
APP_PASSWORD="khnp1234"

# 세션 쿠키 서명용 비밀키 (충분히 긴 랜덤 문자열로 교체)
APP_SECRET="change-me-to-a-long-random-string"

# 거래명세표 OCR(Claude Vision)용 Anthropic API 키는 서버에 저장하지 않고,
# 업로드할 때마다 화면에서 직접 입력합니다.
