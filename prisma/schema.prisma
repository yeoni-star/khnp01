// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Restaurant {
  A
  B
}

enum Category {
  GRAIN // 양곡
  KIMCHI // 김치류
  PRODUCE // 농수산물
  PROCESSED // 공산품
  MEAT // 육류
}

enum SlipStatus {
  DRAFT
  CONFIRMED
}

enum MatchType {
  EXACT
  FUZZY_CONFIRMED
  NONE
}

enum TaxType {
  EXEMPT // 면세
  TAXABLE // 과세
}

model Vendor {
  id         String   @id @default(cuid())
  name       String   @unique
  businessNo String?
  contact    String?
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contracts     Contract[]
  deliverySlips DeliverySlip[]

  @@index([name])
}

model Contract {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  category  Category
  startDate DateTime
  endDate   DateTime
  title     String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ContractItem[]

  @@index([vendorId])
  @@index([startDate, endDate])
}

model ContractItem {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  itemName   String
  category   Category
  unit       String
  unitPrice  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([contractId, itemName])
  @@index([itemName])
}

model DeliverySlip {
  id             String     @id @default(cuid())
  restaurant     Restaurant
  vendorId       String
  vendor         Vendor     @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  deliveryDate   DateTime
  taxType        TaxType    @default(TAXABLE)
  status         SlipStatus @default(DRAFT)
  sourceType     String     @default("MANUAL")
  sourceFileUrl  String?
  ocrRawResponse String?
  confirmedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  items DeliverySlipItem[]

  @@index([restaurant, deliveryDate])
  @@index([vendorId, deliveryDate])
  @@index([status])
}

model DeliverySlipItem {
  id                    String       @id @default(cuid())
  slipId                String
  slip                  DeliverySlip @relation(fields: [slipId], references: [id], onDelete: Cascade)
  itemName              String
  category              Category?
  quantity              Float
  unit                  String
  unitPrice             Int
  amount                Int
  taxAmount             Int?
  matchedContractItemId String?
  matchType             MatchType    @default(NONE)
  priceOverridden       Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([slipId])
  @@index([itemName, category])
}

/** 식당별 검수일지 양식(커스텀 컬럼 정의). columns: Array<{ key, label, type: "CHECK"|"TEXT"|"DATE"|"SELECT", options?: string[] }> */
model InspectionTemplate {
  id         String     @id @default(cuid())
  restaurant Restaurant @unique
  columns    Json
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum InspectionLogStatus {
  DRAFT
  CONFIRMED
}

/** 식당+날짜별 검수일지 1건 */
model InspectionLog {
  id            String              @id @default(cuid())
  restaurant    Restaurant
  logDate       DateTime
  inspectorName String?
  status        InspectionLogStatus @default(DRAFT)
  confirmedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  rows InspectionLogRow[]

  @@unique([restaurant, logDate])
}

/** 검수일지의 각 품목 행. itemName/unit/quantity/vendorName은 불러온 시점의 스냅샷이며,
 * 이후 거래명세표가 수정돼도 검수일지 기록은 바뀌지 않는다. values는 커스텀 컬럼 key -> 값. */
model InspectionLogRow {
  id           String        @id @default(cuid())
  logId        String
  log          InspectionLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  sourceItemId String?
  itemName     String
  unit         String
  quantity     Float
  vendorName   String
  values       Json          @default("{}")
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([logId])
}

/** 사원증 미등록 외부업체(수기장부 대상) 마스터. 식당과 무관하게 공통으로 관리한다. */
model MealCompany {
  id           String   @id @default(cuid())
  name         String   @unique
  pricePerMeal Int
  memo         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  registrations MealRegistration[]

  @@index([name])
}

enum MealType {
  LUNCH
  DINNER
}

/** 공개 제출 폼(/meal-register)을 통해 접수되는 식사 등록 기록. submittedAt은 서버에서 기록하는 실제 제출 시각.
 * mealType은 제출 시각(중식 11:00~13:30 / 석식 17:00~19:30)을 기준으로 서버가 자동 판정한다. */
model MealRegistration {
  id            String      @id @default(cuid())
  restaurant    Restaurant
  companyId     String
  company       MealCompany @relation(fields: [companyId], references: [id], onDelete: Restrict)
  submitterName String
  phone         String
  mealType      MealType
  mealDate      DateTime
  submittedAt   DateTime    @default(now())

  @@index([restaurant, mealDate])
  @@index([companyId, mealDate])
}

/** 중식/석식 신청 가능 시간 설정. 전역 단일 레코드(id="global")로 관리한다.
 * 시간은 KST 기준 "HH:mm" 문자열로 저장한다. */
model MealTimeSettings {
  id               String   @id @default("global")
  lunchStart       String   @default("11:00")
  lunchEnd         String   @default("13:30")
  dinnerStart      String   @default("17:00")
  dinnerEnd        String   @default("19:30")
  updatedAt        DateTime @updatedAt
}
